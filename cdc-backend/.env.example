# ╔══════════════════════════════════════════════════╗
# ║  Java Backend 环境变量配置模板                   ║
# ║  复制为 cdc-backend/.env 或在启动时注入          ║
# ╚══════════════════════════════════════════════════╝

# ===== 数据库 =====
DB_URL=jdbc:mysql://localhost:3306/cdc_knowledge?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai&useSSL=false
DB_USERNAME=root
DB_PASSWORD=123456

# ===== DashScope API（兜底，优先使用前端「LLM 配置」页面管理） =====
DASHSCOPE_API_KEY=your-dashscope-api-key-here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v2

# ===== Agent 服务地址 =====
AGENT_SERVICE_URL=http://localhost:8001
AGENT_SERVICE_TIMEOUT=60000

# ===== 服务端口 =====
SERVER_PORT=8080
