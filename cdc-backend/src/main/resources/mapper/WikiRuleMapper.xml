<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cdc.cdcbackend.mapper.WikiRuleMapper">
    <select id="listByEntityId" resultType="WikiRule">
        SELECT * FROM wiki_rule WHERE entity_id=#{entityId}
    </select>
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO wiki_rule(entity_id,rule_type,content,apply_entity_ids,status,create_time)
        VALUES(#{entityId},#{ruleType},#{content},#{applyEntityIds},#{status},NOW())
    </insert>
    <update id="update">
        UPDATE wiki_rule SET rule_type=#{ruleType}, content=#{content}, apply_entity_ids=#{applyEntityIds}, status=#{status}
        WHERE id=#{id}
    </update>
    <delete id="delete">
        DELETE FROM wiki_rule WHERE id=#{id}
    </delete>
    <delete id="deleteByEntityId">
        DELETE FROM wiki_rule WHERE entity_id=#{entityId}
    </delete>
</mapper>