# ╔══════════════════════════════════════════════════════════╗
# ║  CDC 科普文章生成平台 — Docker 部署环境变量             ║
# ║                                                          ║
# ║  使用方法：                                               ║
# ║  1. cp .env.example .env                                 ║
# ║  2. 编辑 .env 填入实际值                                  ║
# ║  3. docker compose up -d --build                         ║
# ╚══════════════════════════════════════════════════════════╝

# ===== 必填：DashScope API Key =====
# 阿里云百炼平台 API Key（用于 LLM 文本生成 + 向量嵌入 + 图片生成）
# 申请地址：https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your-dashscope-api-key-here

# ===== 数据库 =====
DB_PASSWORD=your-secure-password-here

# ===== LLM 模型配置 =====
# 文本生成模型（可选：qwen-turbo / qwen-plus / qwen-max）
LLM_MODEL=qwen-turbo
# 向量嵌入模型
EMBEDDING_MODEL=text-embedding-v2
# DashScope API 地址（兼容 OpenAI 接口格式的服务均可）
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ===== 端口映射 =====
# Nginx 入口端口（用户访问的端口）
NGINX_PORT=80
# MySQL 端口（如需外部访问数据库，可修改避免冲突）
MYSQL_PORT=3306
# 以下两个端口仅供调试使用，生产环境无需暴露
BACKEND_PORT=8080
AGENT_PORT=8001

# ===== CORS =====
# 生产环境请限定为实际域名（多个域名用逗号分隔）
# CORS_ORIGINS=http://your-domain.com,http://admin.your-domain.com
CORS_ORIGINS=*

# ===== 日志级别 =====
# 可选：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
