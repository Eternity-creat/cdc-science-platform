# ╔══════════════════════════════════════════════════╗
# ║  CDC 科普文章平台 — 环境变量配置模板             ║
# ║                                                  ║
# ║  使用方法：                                       ║
# ║  1. 复制本文件为 .env 并填入实际值                ║
# ║  2. cp .env.example .env                         ║
# ║  3. .env 文件不会被 Git 跟踪，放心填写            ║
# ╚══════════════════════════════════════════════════╝

# ===== 数据库 =====
DB_URL=jdbc:mysql://localhost:3306/cdc_knowledge?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai&useSSL=false
DB_USERNAME=root
DB_PASSWORD=123456

# ===== DashScope API =====
# 阿里云 DashScope API Key（必填，用于 LLM 文本生成 + 向量嵌入 + 图片生成）
# 申请地址：https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your-dashscope-api-key-here

# ===== LLM 模型（兜底默认值，可在前端「LLM 配置」页面管理） =====
LLM_MODEL=qwen-turbo
EMBEDDING_MODEL=text-embedding-v2

# ===== 服务端口（本地开发可保持默认） =====
SERVER_PORT=8080
AGENT_PORT=8001

# ===== 服务间通信（本地开发可保持默认） =====
AGENT_SERVICE_URL=http://localhost:8001
JAVA_BACKEND_URL=http://localhost:8080

# ===== CORS（生产环境请限定域名） =====
# 开发环境用 *，生产环境改为具体域名：
# CORS_ORIGINS=http://your-domain.com,http://admin.your-domain.com
CORS_ORIGINS=*

# ===== 日志级别 =====
LOG_LEVEL=INFO

# ===== 图片生成（可选，大部分场景使用 DashScope 即可） =====
# SENSENOVA_API_KEY=your-sensenova-key-here
# SENSENOVA_BASE_URL=https://api.sensenova.cn
